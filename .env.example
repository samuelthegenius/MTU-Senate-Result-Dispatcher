# Environment Variables

VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Brevo (for email) - 300 emails/day free forever, no domain verification needed
BREVO_API_KEY=your_brevo_api_key
BREVO_FROM_EMAIL=noreply@mtu.edu.ng

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
VITE_TELEGRAM_BOT_USERNAME=your_bot_username_without_at_symbol

# Green API (for WhatsApp) - https://green-api.com
GREENAPI_INSTANCE_ID=your_greenapi_instance_id
GREENAPI_API_TOKEN=your_greenapi_api_token
