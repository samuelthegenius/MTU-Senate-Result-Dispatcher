# Environment Variables

VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-side Supabase credentials (edge functions)
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# CORS - Comma-separated list of allowed origins for API requests
# Defaults include localhost and production domains if not set
ALLOWED_ORIGINS=http://localhost:5173,https://mturesults.app,https://www.mturesults.app

# Brevo (for email) - 300 emails/day free forever, no domain verification needed
BREVO_API_KEY=your_brevo_api_key
BREVO_FROM_EMAIL=noreply@mtu.edu.ng

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
VITE_TELEGRAM_BOT_USERNAME=your_bot_username_without_at_symbol
# Telegram webhook secret - set this in BotFather webhook to prevent fake requests
TELEGRAM_WEBHOOK_SECRET=your_random_secret_here

# Green API (for WhatsApp) - https://green-api.com
GREENAPI_INSTANCE_ID=your_greenapi_instance_id
GREENAPI_API_TOKEN=your_greenapi_api_token

# Portal integration - required for credential encryption
# Generate a strong 32+ character random key for production
PORTAL_ENCRYPTION_KEY=your_strong_random_encryption_key_min_32_chars

# Cron job secret for scheduled sync authorization
CRON_SECRET=your_random_cron_secret_here
